#!/bin/sh

uci -q get mtpoe.@poe[0] || {
	num=0
	board=$(cat /tmp/sysinfo/board_name)
	case "$board" in
	rb-750p-pbr2|\
	mikrotik,routerboard-960pgs)
		num=4
		;;
	mikrotik,rb5009upr)
		num=8
		;;
	*)
		return 0
		;;
	esac
	if [ "$num" -gt 0 ]; then
		uci set mtpoe.poe='poe'
		n=0
		while [ "$n" -lt "$num" ]; do
			uci set mtpoe.poe.port$n='2'
			n=$((n + 1))
		done
		uci commit mtpoe
	fi
}
